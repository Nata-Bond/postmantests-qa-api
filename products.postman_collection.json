    {
      "name": "updateProduct",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "function randomString(length = 10) {",
              "    const chars = \"abcdefghijklmnopqrstuvwxyz\";",
              "    let result = \"\";",
              "",
              "    for (let i = 0; i < length; i++) {",
              "        result += chars.charAt(Math.floor(Math.random() * chars.length));",
              "    }",
              "",
              "    return result;",
              "}",
              "",
              "function generateProduct() {",
              "    const unique = Date.now();",
              "",
              "    return {",
              "        title: `product-${randomString()}-${unique}`,",
              "        price: Math.floor(Math.random() * 10000) + 1,",
              "        description: `description-${randomString(15)}-${unique}`,",
              "        categoryId: Math.floor(Math.random() * 8) + 1,",
              "        images: [",
              "            `https://placehold.co/600x400?text=${unique}`",
              "        ]",
              "    };",
              "}",
              "",
              "const product = generateProduct();",
              "",
              "// зберігаємо всі дані",
              "Object.entries(product).forEach(([key, value]) => {",
              "    pm.collectionVariables.set(",
              "        key,",
              "        Array.isArray(value) ? JSON.stringify(value) : value",
              "    );",
              "});",
              "",
              "pm.sendRequest({",
              "    url: \"https://api.escuelajs.co/api/v1/products/\",",
              "    method: \"POST\",",
              "    header: {",
              "        \"Content-Type\": \"application/json\"",
              "    },",
              "    body: {",
              "        mode: \"raw\",",
              "        raw: JSON.stringify(product)",
              "    }",
              "}, function (err, res) {",
              "",
              "    if (err) {",
              "        console.log(err);",
              "        return;",
              "    }",
              "",
              "    const createdProduct = res.json();",
              "",
              "    pm.collectionVariables.set(\"productId\", createdProduct.id);",
              "",
              "    console.log(createdProduct);",
              "});",
              "",
              "function randomString(length = 10) {",
              "",
              "    const chars = \"abcdefghijklmnopqrstuvwxyz\";",
              "",
              "    let result = \"\";",
              "",
              "    for (let i = 0; i < length; i++) {",
              "",
              "        result += chars.charAt(Math.floor(Math.random() * chars.length));",
              "",
              "    }",
              "",
              "    return result;",
              "",
              "}",
              "",
              "function generateUpdatedProduct() {",
              "",
              "    const unique = Date.now();",
              "",
              "    return {",
              "",
              "        updatedTitle: `updated-${randomString()}-${unique}`,",
              "",
              "        updatedPrice: Math.floor(Math.random() * 10000) + 1,",
              "",
              "        updatedDescription: `updated-description-${randomString(15)}-${unique}`,",
              "",
              "        updatedCategoryId: Math.floor(Math.random() * 8) + 1,",
              "",
              "        updatedImages: JSON.stringify([",
              "",
              "            `https://placehold.co/600x400?updated=${unique}`",
              "",
              "        ])",
              "",
              "    };",
              "",
              "}",
              "",
              "const updatedProduct = generateUpdatedProduct();",
              "",
              "Object.entries(updatedProduct).forEach(([key, value]) => {",
              "",
              "    pm.collectionVariables.set(key, value);",
              "",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "pm.response.to.have.status(200)});",
              "",
              "pm.test(\"Status name is OK\", function () {",
              "    pm.response.to.have.status(\"OK\")}); ",
              "",
              "pm.test(\"Response time is less than 1000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000)});",
              "",
              "pm.test(\"Response is json\", function () {",
              "    pm.response.to.be.json});",
              "",
              "    const body = pm.response.json();",
              "",
              "pm.test(\"Title updated\", () => {",
              "    pm.expect(body.title).to.eql(pm.collectionVariables.get(\"updatedTitle\"));",
              "});",
              "",
              "pm.test(\"Price updated\", () => {",
              "    pm.expect(body.price).to.eql(Number(pm.collectionVariables.get(\"updatedPrice\")));",
              "});",
              "",
              "pm.test(\"Description updated\", () => {",
              "    pm.expect(body.description).to.eql(pm.collectionVariables.get(\"updatedDescription\"));",
              "});",
              "",
              "pm.test(\"Category updated\", () => {",
              "    pm.expect(body.category.id).to.eql(Number(pm.collectionVariables.get(\"updatedCategoryId\")));",
              "});",
              "",
              "pm.test(\"Images updated\", () => {",
              "    pm.expect(body.images).to.eql(JSON.parse(pm.collectionVariables.get(\"updatedImages\")));",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
