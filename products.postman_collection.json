    {
      "name": "deleteProduct",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "function generateRandomTitle(length = 10) {",
              "    const chars = 'abcdefghijklmnopqrstuvwxyz';",
              "    let title = '';",
              "",
              "    for (let i = 0; i < length; i++) {",
              "        title += chars.charAt(Math.floor(Math.random() * chars.length));",
              "    }",
              "",
              "    // додаємо timestamp для гарантії унікальності",
              "    return `${title}-${Date.now()}`;",
              "}",
              "",
              "const title = generateRandomTitle();",
              "const categoryId = Math.floor(Math.random() * 8) + 1;",
              "",
              "const product = {",
              "    title,",
              "    price: 10,",
              "    description: \"A description\",",
              "    categoryId,",
              "    images: [\"https://placehold.co/600x400\"]",
              "};",
              "",
              "pm.collectionVariables.set(\"title\", title);",
              "pm.collectionVariables.set(\"categoryId\", categoryId);",
              "",
              "pm.sendRequest({",
              "    url: \"https://api.escuelajs.co/api/v1/products/\",",
              "    method: \"POST\",",
              "    header: {",
              "        \"Content-Type\": \"application/json\"",
              "    },",
              "    body: {",
              "        mode: \"raw\",",
              "        raw: JSON.stringify(product)",
              "    }",
              "}, function (err, res) {",
              "",
              "    if (err) {",
              "        console.log(err);",
              "        return;",
              "    }",
              "",
              "    const createdProduct = res.json();",
              "",
              "    pm.collectionVariables.set(\"deleteProductId\", createdProduct.id);",
              "",
              "    console.log(\"Created product:\", createdProduct);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 204\", function () {",
              "pm.response.to.have.status(204)});",
              "",
              "pm.test(\"Status name is OK\", function () {",
              "    pm.response.to.have.status(\"OK\")}); ",
              "",
              "pm.test(\"Response time is less than 1000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(1000)});",
              "",
              "pm.test(\"Response is true\", () => {",
              "    pm.expect(pm.response.json()).to.be.true;",
              "",
              "});",
              "",
              "const deleteProductId = pm.collectionVariables.get(\"deleteProductId\");",
              "",
              "pm.sendRequest({",
              "",
              "    url: `https://api.escuelajs.co/api/v1/products/${deleteProductId}`,",
              "",
              "    method: \"GET\"",
              "",
              "}, function (err, res) {",
              "",
              "    pm.test(\"Deleted product cannot be retrieved\", function () {",
              "",
              "        pm.expect(err).to.be.null;",
              "",
              "        pm.expect(res.code).to.eql(404);",
              "",
              "    });",
              "",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
